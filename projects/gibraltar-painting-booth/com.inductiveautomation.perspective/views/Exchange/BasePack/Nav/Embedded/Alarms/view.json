{
  "custom": {
    "numAlarms": 25
  },
  "params": {
    "enableModal": false,
    "iconOnly": false
  },
  "propConfig": {
    "custom.numAlarms": {
      "binding": {
        "config": {
          "expression": "if(!{view.params.iconOnly}, now(2000), false)"
        },
        "transforms": [
          {
            "code": "\treturn len(system.alarm.queryStatus(state\u003d[\"ActiveUnacked\",\"ActiveAcked\"]))",
            "type": "script"
          }
        ],
        "type": "expr"
      },
      "persistent": true
    },
    "params.enableModal": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.iconOnly": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 40,
      "width": 250
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "Icon"
            },
            "position": {
              "basis": "40px",
              "shrink": 0
            },
            "props": {
              "path": "material/alarm",
              "style": {
                "classes": "",
                "padding": "8px"
              }
            },
            "type": "ia.display.icon"
          },
          {
            "meta": {
              "name": "Label"
            },
            "position": {
              "basis": "50px",
              "grow": 1
            },
            "propConfig": {
              "position.display": {
                "binding": {
                  "config": {
                    "expression": "!{view.params.iconOnly}"
                  },
                  "type": "expr"
                }
              },
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "{view.custom.numAlarms}"
                  },
                  "transforms": [
                    {
                      "expression": "numberFormat({value}, \"#,##0\")",
                      "type": "expression"
                    }
                  ],
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "overflow": "hidden"
              },
              "textStyle": {
                "paddingRight": 8,
                "whiteSpace": "nowrap"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "events": {
          "dom": {
            "onClick": {
              "config": {
                "script": "\tif self.view.params.enableModal:\n\t\tsystem.perspective.openPopup(\n\t\tid\u003dself.page.props.pageId + \"-Alarms-Menu\",\n\t\tview\u003d\"Exchange/BasePack/Nav/Embedded/Alarms Menu\",\n\t\tshowCloseIcon\u003dFalse,\n\t\tdraggable\u003dFalse,\n\t\tresizable\u003dFalse,\n\t\tmodal\u003dTrue,\n\t\toverlayDismiss\u003dTrue,\n\t\tviewportBound\u003dTrue,\n\t\tposition \u003d {\u0027left\u0027:event.clientX - 700, \u0027top\u0027: 50} # relative\n#\t\tposition \u003d {\"left\": self.position.x,\"top\": self.position.y + self.position.height},\n\t\t)\n\telse:\n\t\tsystem.perspective.navigate(page\u003d\"/alarms\")"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "contextMenu": {
            "enabled": true
          },
          "name": "FlexContainer",
          "tooltip": {
            "enabled": true,
            "location": "bottom",
            "text": "Alarm Menu"
          }
        },
        "position": {
          "grow": 1
        },
        "props": {
          "style": {
            "overflow": "hidden"
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "domId": "nav-theme",
      "name": "root"
    },
    "propConfig": {
      "props.style.classes": {
        "binding": {
          "config": {
            "expression": "if({view.custom.numAlarms} \u003e 0, \u0027nav-alarm-item\u0027,\u0027\u0027)"
          },
          "type": "expr"
        }
      }
    },
    "props": {
      "style": {
        "overflow": "hidden"
      }
    },
    "type": "ia.container.flex"
  }
}