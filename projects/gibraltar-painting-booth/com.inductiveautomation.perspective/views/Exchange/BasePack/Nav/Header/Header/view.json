{
  "custom": {
    "size": "small"
  },
  "params": {
    "params": {}
  },
  "propConfig": {
    "custom.size": {
      "binding": {
        "config": {
          "path": "page.props.dimensions.viewport.width"
        },
        "transforms": [
          {
            "fallback": "large",
            "inputType": "range",
            "mappings": [
              {
                "input": {
                  "max": 1000,
                  "min": 0
                },
                "output": "small"
              }
            ],
            "outputType": "scalar",
            "type": "map"
          },
          {
            "expression": "if({session.props.device.type}\u003d\u0027designer\u0027,\"large\",{value})",
            "type": "expression"
          }
        ],
        "type": "property"
      },
      "persistent": true
    },
    "params.params": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 50,
      "width": 1000
    }
  },
  "root": {
    "children": [
      {
        "events": {
          "dom": {
            "onClick": [
              {
                "config": {
                  "script": "\tif self.props.path \u003d\u003d \u0027material/menu\u0027:\n\t\tsystem.perspective.openDock(id\u003d\u0027menu\u0027)\n\t\tself.props.path \u003d \u0027material/menu_open\u0027\n#\t\tsystem.perspective.alterDock(dockId\u003d\u0027menu\u0027, config\u003d{\u0027display\u0027:\u0027visible\u0027, \u0027content\u0027:\u0027push\u0027})\n\t\t\n\telse:\n\t\tsystem.perspective.closeDock(id\u003d\u0027menu\u0027)\n\t\tself.props.path \u003d \u0027material/menu\u0027\n#\t\tsystem.perspective.alterDock(dockId\u003d\u0027menu\u0027, config\u003d{\u0027display\u0027:\u0027onDemand\u0027, \u0027content\u0027:\u0027push\u0027})"
                },
                "enabled": false,
                "scope": "G",
                "type": "script"
              },
              {
                "config": {
                  "script": "\tif not self.session.custom.navigation.sideMenu.leftOpen:\n\t\tself.session.custom.navigation.sideMenu.leftOpen \u003d True\n\telse:\n\t\tself.session.custom.navigation.sideMenu.leftOpen \u003d False"
                },
                "scope": "G",
                "type": "script"
              }
            ]
          }
        },
        "meta": {
          "name": "Menu Action",
          "tooltip": {
            "delay": 1000,
            "enabled": true,
            "location": "center-right"
          }
        },
        "position": {
          "basis": "40px",
          "shrink": 0
        },
        "propConfig": {
          "meta.tooltip.text": {
            "binding": {
              "config": {
                "expression": "if({session.custom.navigation.sideMenu.leftOpen},\u0027Close sidebar\u0027,\u0027Keep sidebar\u0027)"
              },
              "type": "expr"
            }
          },
          "props.path": {
            "binding": {
              "config": {
                "expression": "if({session.custom.navigation.sideMenu.leftOpen},\u0027material/menu_open\u0027,\u0027material/menu\u0027)"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "classes": "nav-header-button",
            "display": "flex"
          }
        },
        "type": "ia.display.icon"
      },
      {
        "meta": {
          "name": "Separator"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "style": {
            "classes": "nav-header-button-separator"
          }
        },
        "type": "ia.display.label"
      },
      {
        "events": {
          "dom": {
            "onClick": {
              "config": {
                "script": "\tsystem.perspective.navigateBack()"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "Nav Back",
          "tooltip": {
            "delay": 1000,
            "enabled": true,
            "location": "bottom",
            "text": "Navigate Back"
          }
        },
        "position": {
          "basis": "40px",
          "shrink": 0
        },
        "props": {
