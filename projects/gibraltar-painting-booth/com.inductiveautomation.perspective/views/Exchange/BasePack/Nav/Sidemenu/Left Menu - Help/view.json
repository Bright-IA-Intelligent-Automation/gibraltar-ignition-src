{
  "custom": {
    "size": "small"
  },
  "params": {},
  "propConfig": {
    "custom.size": {
      "binding": {
        "config": {
          "path": "page.props.dimensions.viewport.width"
        },
        "transforms": [
          {
            "fallback": "large",
            "inputType": "range",
            "mappings": [
              {
                "input": {
                  "max": 1000,
                  "min": 0
                },
                "output": "small"
              }
            ],
            "outputType": "scalar",
            "type": "map"
          },
          {
            "expression": "if({session.props.device.type}\u003d\u0027designer\u0027,\"small\",{value})",
            "type": "expression"
          }
        ],
        "type": "property"
      },
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "width": 300
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "Link"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "loading": {
            "order": "with-parent"
          },
          "params": {
            "icon": "material/help",
            "isLink": true,
            "label": "Home",
            "showArrow": false,
            "target": "/help"
          },
          "path": "Exchange/BasePack/Nav/Sidemenu/Embedded/Link"
        },
        "type": "ia.display.view"
      },
      {
        "meta": {
          "name": "Label"
        },
        "position": {
          "display": null,
          "shrink": 0
        },
        "props": {
          "style": {
            "classes": "nav-section-separator "
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "Link_0"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "loading": {
            "order": "with-parent"
          },
          "params": {
            "icon": "material/help",
            "isLink": true,
            "label": "Documentation",
            "showArrow": false,
            "target": "/help/documentation"
          },
          "path": "Exchange/BasePack/Nav/Sidemenu/Embedded/Link"
        },
        "type": "ia.display.view"
      },
      {
        "meta": {
          "name": "Link_1"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "loading": {
            "order": "with-parent"
          },
          "params": {
            "icon": "material/help",
            "isLink": true,
            "label": "FAQs",
            "showArrow": false,
            "target": "/help/faq"
          },
          "path": "Exchange/BasePack/Nav/Sidemenu/Embedded/Link"
        },
        "type": "ia.display.view"
      }
    ],
    "meta": {
      "name": "root"
    },
    "propConfig": {
      "props.style.classes": {
        "binding": {
          "config": {
            "expression": "if({session.props.device.type}\u003d\u0027designer\u0027,\r\n\u0027nav nav-open \u0027,\r\nif({session.custom.navigation.sideMenu.leftOpen},\r\n\u0027nav nav-open \u0027,\r\n\u0027nav \u0027))"
          },
          "type": "expr"
        }
      }
    },
    "props": {
      "direction": "column",
      "style": {}
    },
    "type": "ia.container.flex"
  }
}