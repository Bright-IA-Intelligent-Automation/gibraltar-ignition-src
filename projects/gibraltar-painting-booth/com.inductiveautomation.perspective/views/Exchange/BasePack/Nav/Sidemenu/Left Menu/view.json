        "type": "ia.display.icon"
      }
    ],
    "meta": {
      "name": "root"
    },
    "propConfig": {
      "props.style.classes": {
        "binding": {
          "config": {
            "expression": "if({session.props.device.type}\u003d\u0027designer\u0027,\r\n\u0027nav nav-open \u0027,\r\nif({session.custom.navigation.sideMenu.leftOpen},\r\n\u0027nav nav-open \u0027,\r\n\u0027nav \u0027))"
          },
          "type": "expr"
        }
      }
    },
    "props": {
