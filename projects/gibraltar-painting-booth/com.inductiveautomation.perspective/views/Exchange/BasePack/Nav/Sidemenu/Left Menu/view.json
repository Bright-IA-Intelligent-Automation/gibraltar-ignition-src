{
  "custom": {
    "size": "small"
  },
  "params": {},
  "propConfig": {
    "custom.size": {
      "binding": {
        "config": {
          "path": "page.props.dimensions.viewport.width"
        },
        "transforms": [
          {
            "fallback": "large",
            "inputType": "range",
            "mappings": [
              {
                "input": {
                  "max": 1000,
                  "min": 0
                },
                "output": "small"
              }
            ],
            "outputType": "scalar",
            "type": "map"
          },
          {
            "expression": "if({session.props.device.type}\u003d\u0027designer\u0027,\"small\",{value})",
            "type": "expression"
          }
        ],
        "type": "property"
      },
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "width": 269
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "Home"
        },
        "position": {
          "shrink": 0
        },
